<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>2026 紫色生活流水帳 - Web App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #f8f7ff;
            font-family: 'PingFang TC', 'Microsoft JhengHei', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }
        .glass-header {
            background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
            position: sticky;
            top: 0;
            z-index: 50;
        }
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        .category-label-input {
            background: transparent;
            border: none;
            width: 100%;
            font-size: 9px;
            color: #64748b;
            font-weight: 700;
            text-align: center;
            outline: none;
        }
        .item-note-input {
            font-size: 8px;
            padding: 0px 2px;
            border-radius: 3px;
            border: 1px dashed #eee;
            width: 100%;
            height: 14px;
            margin-bottom: 1px;
            outline: none;
            background: #fff;
            text-align: center;
        }
        .day-card {
            background: white;
            border-radius: 0.75rem;
            padding: 0.6rem 0.75rem;
            box-shadow: 0 1px 5px rgba(139, 92, 246, 0.05);
            border: 1px solid #f3f0ff;
        }
        .item-box {
            background-color: #fcfbff;
            border-radius: 6px;
            padding: 2px;
            border: 1px solid #f8f6ff;
        }
        .featured-box {
            background-color: #f5f3ff;
            border: 1px solid #ede9fe;
        }
        .wallet-zone {
            background: #f1f0ff;
            border-radius: 0.75rem;
            padding: 0.35rem 0.6rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-grow: 1;
        }
        .wallet-input {
            background: white;
            border-radius: 6px;
            text-align: center;
            font-weight: 900;
            font-size: 13px;
            color: #4338ca;
            border: 1px solid #e0e7ff;
            width: 3.5rem;
            padding: 2px 0;
            outline: none;
        }
        #saveIndicator {
            transition: opacity 0.3s;
        }
    </style>
</head>
<body class="min-h-screen pb-20">
    <header class="glass-header text-white shadow-lg p-2 mb-2">
        <div class="max-w-5xl mx-auto flex justify-between items-center px-1">
            <div class="flex flex-col">
                <h1 class="text-base font-bold leading-none">💜 2026 雲端流水帳</h1>
                <div class="flex items-center gap-1 mt-1">
                    <span id="syncStatus" class="inline-block w-1.5 h-1.5 rounded-full bg-yellow-400"></span>
                    <p class="text-[8px] text-purple-100 opacity-80" id="statusText">正在同步中...</p>
                </div>
            </div>
            <div class="flex gap-3 text-right items-center">
                <div class="flex flex-col">
                    <span class="text-[7px] opacity-70 font-bold">總支出</span>
                    <span class="text-base font-black" id="totalExpenseToday">$ 0</span>
                </div>
                <div class="flex flex-col border-l border-white/20 pl-3">
                    <span class="text-[7px] opacity-70 font-bold">預計餘額</span>
                    <span class="text-base font-black text-yellow-300" id="finalWalletBalance">$ 0</span>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-5xl mx-auto px-2">
        <div id="expenseList" class="space-y-2.5 text-center py-10 text-purple-300">
            載入雲端資料中...
        </div>
    </main>

    <div id="saveIndicator" class="fixed bottom-4 right-4 bg-black/60 text-white text-[10px] px-3 py-1 rounded-full opacity-0 pointer-events-none z-50">
        已儲存至雲端
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        const firebaseConfig = JSON.parse(__firebase_config);
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';

        const START_DATE = new Date('2026-03-26');
        const END_DATE = new Date('2026-12-31');
        
        const defaultCategories = [
            { key: 'breakfast', label: '早餐', icon: '🥐', editable: false, hasNote: true },
            { key: 'lunch', label: '午餐', icon: '🍱', editable: false, hasNote: true },
            { key: 'dinner', label: '晚餐', icon: '🥘', editable: false, hasNote: true },
            { key: 'drink', label: '飲料', icon: '🧋', editable: false, hasNote: false },
            { key: 'smoke', label: '煙', icon: '🚬', editable: false, hasNote: false },
            { key: 'yunlin', label: '雲林開銷', icon: '💰', editable: false, hasNote: true },
            { key: 'bill', label: '繳費', icon: '💸', editable: false, hasNote: true },
            { key: 'others', label: '自訂1', icon: '🎀', editable: true, hasNote: true },
            { key: 'others2', label: '自訂2', icon: '🌸', editable: true, hasNote: true },
            { key: 'others3', label: '自訂3', icon: '🌷', editable: true, hasNote: true },
            { key: 'card1', label: '刷卡A', icon: '💳', editable: true, hasNote: true },
            { key: 'card2', label: '刷卡B', icon: '💳', editable: true, hasNote: true }
        ];

        let allData = {};
        let customLabels = {};
        let currentUser = null;

        // 登入邏輯 (Rule 3)
        const initAuth = async () => {
            if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                await signInWithCustomToken(auth, __initial_auth_token);
            } else {
                await signInAnonymously(auth);
            }
        };
        initAuth();

        onAuthStateChanged(auth, (user) => {
            if (user) {
                currentUser = user;
                document.getElementById('syncStatus').className = 'inline-block w-1.5 h-1.5 rounded-full bg-green-400';
                document.getElementById('statusText').innerText = '雲端已連線';
                subscribeToData();
            }
        });

        function subscribeToData() {
            if (!currentUser) return;

            // 訂閱標籤 (Rule 1)
            const labelsDoc = doc(db, 'artifacts', appId, 'users', currentUser.uid, 'settings', 'labels');
            onSnapshot(labelsDoc, (snap) => {
                if (snap.exists()) customLabels = snap.data();
                renderList();
            }, (err) => console.error(err));

            // 訂閱數據 (Rule 1)
            const dataDoc = doc(db, 'artifacts', appId, 'users', currentUser.uid, 'data', 'all_expenses');
            onSnapshot(dataDoc, (snap) => {
                if (snap.exists()) allData = snap.data();
                renderList();
            }, (err) => console.error(err));
        }

        function renderList() {
            let html = '';
            let current = new Date(START_DATE);

            while (current <= END_DATE) {
                const dateStr = current.toISOString().split('T')[0];
                const dayOfWeek = ['日', '一', '二', '三', '四', '五', '六'][current.getDay()];
                const isWeekend = current.getDay() === 0 || current.getDay() === 6;

                if (current.getDate() === 1 || dateStr === '2026-03-26') {
                    html += `<div class="pt-4 pb-1 px-1"><h2 class="text-xl font-black text-purple-900">${(current.getMonth() + 1)}月</h2></div>`;
                }

                const dD = allData[dateStr] || {};
                
                html += `
                    <div class="day-card">
                        <div class="flex flex-col gap-2.5">
                            <div class="flex items-center gap-3 border-b border-purple-50 pb-2">
                                <div class="${isWeekend ? 'text-red-500' : 'text-purple-600'} shrink-0 px-1">
                                    <div class="text-[10px] font-bold opacity-70 uppercase tracking-tighter">${dateStr.split('-')[1]}/${dateStr.split('-')[2]}</div>
                                    <div class="text-base font-black leading-none mt-0.5">周${dayOfWeek}</div>
                                </div>
                                <div class="wallet-zone">
                                    <div class="flex items-center gap-1.5">
                                        <span class="text-[10px] font-bold text-purple-500">錢包</span>
                                        <input type="number" oninput="updateCloud('${dateStr}','base',this.value)" value="${dD.base||''}" class="wallet-input">
                                    </div>
                                    <div class="w-px h-6 bg-purple-200"></div>
                                    <div class="flex items-center gap-1.5">
                                        <span class="text-[10px] font-bold text-blue-500">拿取</span>
                                        <input type="number" oninput="updateCloud('${dateStr}','draw',this.value)" value="${dD.draw||''}" class="wallet-input !text-blue-700 !border-blue-100">
                                    </div>
                                    <div class="ml-auto flex items-center gap-2 pr-1">
                                        <span class="text-[10px] font-bold text-gray-400">剩下</span>
                                        <span class="text-sm font-black text-purple-700" id="wallet-rem-${dateStr}">$0</span>
                                    </div>
                                </div>
                            </div>
                            <div class="grid grid-cols-4 sm:grid-cols-6 gap-1.5">
                                ${defaultCategories.map(c => `
                                    <div class="flex flex-col item-box featured-box">
                                        <input type="text" value="${customLabels[c.key]||c.label}" ${!c.editable?'readonly':''} onblur="updateLabelCloud('${c.key}',this.value)" class="category-label-input">
                                        ${c.hasNote ? `<input type="text" oninput="updateCloud('${dateStr}','${c.key}_n',this.value)" value="${dD[c.key+'_n']||''}" placeholder="..." class="item-note-input">` : ''}
                                        <div class="relative">
                                            <span class="absolute left-1 top-1/2 -translate-y-1/2 text-[8px]">${c.icon}</span>
                                            <input type="number" oninput="updateCloud('${dateStr}','${c.key}',this.value)" value="${dD[c.key]||''}" class="w-full pl-3.5 pr-0.5 py-0.5 bg-transparent rounded text-[11px] font-black outline-none text-right">
                                        </div>
                                    </div>
                                `).join('')}
                            </div>
                            <div class="flex justify-between items-center pt-1 px-1">
                                <div class="flex items-center gap-1.5">
                                    <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">口袋</span>
                                    <span class="text-xs font-black" id="pocket-${dateStr}">$0</span>
                                </div>
                                <div class="flex items-center gap-1.5">
                                    <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">本日花費</span>
                                    <span class="text-sm font-black text-purple-600" id="exp-${dateStr}">$0</span>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                current.setDate(current.getDate() + 1);
            }
            document.getElementById('expenseList').innerHTML = html;
            calc();
        }

        // 防抖動機制與雲端更新
        let timer;
        window.updateCloud = (d, t, v) => {
            if (!currentUser) return;
            if (!allData[d]) allData[d] = {};
            allData[d][t] = v;
            calc(); // 先本地計算即時回饋
            clearTimeout(timer);
            timer = setTimeout(async () => {
                const dataDoc = doc(db, 'artifacts', appId, 'users', currentUser.uid, 'data', 'all_expenses');
                document.getElementById('saveIndicator').style.opacity = '1';
                await setDoc(dataDoc, allData);
                setTimeout(() => document.getElementById('saveIndicator').style.opacity = '0', 2000);
            }, 1000);
        };

        window.updateLabelCloud = async (k, v) => {
            if (!currentUser) return;
            customLabels[k] = v;
            const labelsDoc = doc(db, 'artifacts', appId, 'users', currentUser.uid, 'settings', 'labels');
            await setDoc(labelsDoc, customLabels);
        };

        function calc() {
            let runningBalance = 0;
            let current = new Date(START_DATE);
            while (current <= END_DATE) {
                const ds = current.toISOString().split('T')[0];
                const dD = allData[ds] || {};
                let base = (dD.base !== undefined && dD.base !== '') ? Number(dD.base) : runningBalance;
                let dr = Number(dD.draw) || 0;
                let dayEx = 0;
                defaultCategories.forEach(c => dayEx += (Number(dD[c.key]) || 0));
                let pkt = dr - dayEx; 
                let walletRem = base - dr;
                runningBalance = walletRem + pkt;
                if(document.getElementById(`wallet-rem-${ds}`)) document.getElementById(`wallet-rem-${ds}`).innerText = `$${walletRem.toLocaleString()}`;
                if(document.getElementById(`exp-${ds}`)) document.getElementById(`exp-${ds}`).innerText = `$${dayEx.toLocaleString()}`;
                if(document.getElementById(`pocket-${ds}`)) {
                    const pEl = document.getElementById(`pocket-${ds}`);
                    pEl.innerText = `$${pkt.toLocaleString()}`;
                    pEl.className = pkt < 0 ? 'text-xs font-black text-red-500' : 'text-xs font-black text-green-600';
                }
                current.setDate(current.getDate() + 1);
            }
            document.getElementById('finalWalletBalance').innerText = `$ ${runningBalance.toLocaleString()}`;
            const today = new Date().toISOString().split('T')[0];
            let tS = 0;
            if(allData[today]) defaultCategories.forEach(c => tS += (Number(allData[today][c.key]) || 0));
            document.getElementById('totalExpenseToday').innerText = `$ ${tS.toLocaleString()}`;
        }
    </script>
</body>
</html>

